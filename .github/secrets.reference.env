# CarClinch GitHub Actions — Secrets Reference
# -----------------------------------------------
# This file documents every secret needed for CI/CD.
# DO NOT put real values here. This is a reference only.
# Share this file with the team so everyone knows what's needed.
#
# To get the actual values:
#   - Terraform outputs: run `terraform output` in the /core/infra directory
#   - Azure credentials: run `az ad sp create-for-rbac --sdk-auth` (see below)
#   - Storage key: Azure Portal → Storage Account → Access Keys
#
# To set secrets in GitHub:
#   Repo → Settings → Secrets and variables → Actions → New repository secret

# ── Azure Credentials (for deploying to Azure) ────────────────────────────────
# Run this command and paste the ENTIRE JSON output as the secret value:
#
# az ad sp create-for-rbac \
#   --name "carclinch-github-actions" \
#   --role contributor \
#   --scopes /subscriptions/<YOUR_SUB_ID>/resourceGroups/rg-carclinch-dev \
#   --sdk-auth
#
AZURE_CREDENTIALS=

# ── Azure Container Registry (from: terraform output) ─────────────────────────
# ACR_LOGIN_SERVER  → terraform output acr_login_server        e.g. carclinchdev123.azurecr.io
# ACR_NAME          → terraform output acr_name                e.g. carclinchdev123  (no .azurecr.io)
# ACR_USERNAME      → terraform output -raw acr_admin_username
# ACR_PASSWORD      → terraform output -raw acr_admin_password
ACR_LOGIN_SERVER=
ACR_NAME=
ACR_USERNAME=
ACR_PASSWORD=

# ── Azure Blob Storage (from: terraform output + Azure Portal) ─────────────────
# AZURE_STORAGE_ACCOUNT_NAME   → terraform output storage_account_name
# AZURE_STORAGE_CONTAINER_NAME → processed-images (hardcoded in Terraform)
# AZURE_STORAGE_ACCOUNT_KEY    → Azure Portal → Storage Account → Access Keys → key1
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=processed-images